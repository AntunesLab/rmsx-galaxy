<macros>
    <token name="@TOOL_VERSION@">0.1.0</token>
    <token name="@RMSX_SOURCE_REF@">v0.2.3</token>
    <token name="@VERSION_SUFFIX@">0</token>
    <token name="@CONTAINER_IMAGE@">ghcr.io/antuneslab/flipbook-galaxy:0.2.3-galaxy0</token>

    <xml name="requirements">
        <requirements>
            <!--
            RMSX is not yet packaged as a Galaxy-ready Conda dependency.
            This requirement documents the intended executable dependency for the
            first wrapper scaffold. See README.rst and packaging/flipbook-galaxy/ for
            local development and container packaging notes.
            The temporary container pins upstream source ref @RMSX_SOURCE_REF@,
            whose Python package metadata currently reports @TOOL_VERSION@.
            -->
            <requirement type="package" version="@TOOL_VERSION@">rmsx</requirement>
            <requirement type="package" version="2.10.0">mdanalysis</requirement>
            <requirement type="package" version="3.0.3">pandas</requirement>
            <requirement type="package" version="2.4.6">numpy</requirement>
            <requirement type="package" version="6.8.0">plotly</requirement>
            <requirement type="package" version="9.14.1">ipython</requirement>
            <requirement type="package" version="4.5.3">r-base</requirement>
            <requirement type="package" version="4.0.3">r-ggplot2</requirement>
            <requirement type="package" version="0.6.5">r-viridis</requirement>
            <requirement type="package" version="1.2.1">r-dplyr</requirement>
            <requirement type="package" version="1.3.2">r-tidyr</requirement>
            <requirement type="package" version="1.6.0">r-stringr</requirement>
            <requirement type="package" version="2.2.0">r-readr</requirement>
            <requirement type="package" version="2.3">r-gridextra</requirement>
            <requirement type="package" version="1.3.1">r-ggpattern</requirement>
            <container type="docker">@CONTAINER_IMAGE@</container>
        </requirements>
    </xml>

    <xml name="citations">
        <citations>
            <citation type="doi">10.1038/s41598-026-39869-7</citation>
            <citation type="doi">10.25080/majora-629e541a-00e</citation>
        </citations>
    </xml>
</macros>
